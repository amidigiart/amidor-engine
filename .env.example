# Copiaza in .env si completeaza. NU comita .env.
AMIDOR_ENV=dev                       # "prod" refuza PIN implicit
AMIDOR_FAMILY_PIN=schimba-ma
AMIDOR_JOURNAL_CONSENT=false         # "true" DOAR cu consimtamantul persoanei
AMIDOR_CONCORDANCE=0.45

# Motor dual - 2 endpointuri (in prod: 2 modele EU distincte, vezi BLUEPRINT)
MODEL_A_URL=http://localhost:11434/v1
MODEL_A_NAME=gemma3:4b
MODEL_B_URL=http://localhost:11434/v1
MODEL_B_NAME=gemma3:4b
# MODEL_A_KEY=...  MODEL_B_KEY=...
