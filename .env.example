# Copiaza in .env si completeaza. NU comita .env.
AMIDOR_ENV=dev                       # "prod" refuza PIN implicit
AMIDOR_FAMILY_PIN=schimba-ma
AMIDOR_JOURNAL_CONSENT=false         # "true" DOAR cu consimtamantul persoanei
AMIDOR_CONCORDANCE=0.45

# Motor dual - 2 endpointuri (in prod: 2 modele EU distincte, vezi BLUEPRINT)
MODEL_A_URL=http://localhost:11434/v1
MODEL_A_NAME=gemma3:4b
MODEL_B_URL=http://localhost:11434/v1
MODEL_B_NAME=gemma3:4b
# MODEL_A_KEY=...  MODEL_B_KEY=...

# Voce LOCALA optionala (GDPR-curata). Fara ele, browserul face STT/TTS
# (cu nota de confidentialitate afisata utilizatorului).
# PIPER_BIN=/opt/piper/piper
# PIPER_VOICE_RO=/opt/piper/voices/ro_RO.onnx
# PIPER_VOICE_EN=/opt/piper/voices/en_GB.onnx

# Alerte familie (Sprint 4) — se declanseaza la interceptare de escrocherie.
# NU trimit continut de conversatie, doar evenimentul (minimizare GDPR). Log mereu activ.
ALERT_ON_SCAM=true
ALERT_COOLDOWN=300
# ALERT_EMAIL_TO=fiul@example.com
# ALERT_SMTP_HOST=smtp.example.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=...
# ALERT_SMTP_PASS=...
# ALERT_WEBHOOK_URL=https://...   (ex. bot Telegram/Signal)

# --- MOD N-MODEL (optional): adauga un al 3-lea/4-lea model si devine ansamblu WEAC ---
# Cate modele configurezi (min 2), atatea intra. >=3 => EnsembleEngine automat.
# MODEL_C_URL=https://api.deepseek.com/v1
# MODEL_C_NAME=deepseek-chat
# MODEL_C_KEY=
# MODEL_A_WEIGHT=1.0   # ponderi de incredere per model (default 1.0)
# MODEL_B_WEIGHT=1.0
# MODEL_C_WEIGHT=0.8
