# Copiaza in deploy/.env si completeaza. NU comita .env.

AMIDOR_ENV=prod
AMIDOR_FAMILY_PIN=schimba-ma-neaparat          # prod refuza PIN implicit
AMIDOR_ACCESS_CODE=                            # cod pt familii pilot (gol = deschis)
AMIDOR_JOURNAL_CONSENT=false                   # "true" DOAR cu consimtamantul persoanei
AMIDOR_CONCORDANCE=0.45
QID=1820209090023

# --- MOTOR DUAL (conformitate GDPR: endpointuri UE / self-hosted) ---
# Model A: API EU. Mistral (Franta) e o alegere curata.
MODEL_A_URL=https://api.mistral.ai/v1
MODEL_A_NAME=mistral-small-latest
MODEL_A_KEY=

# Model B: Ollama local pe VPS (setat de compose la http://ollama:11434/v1).
MODEL_B_NAME=mistral            # sau deepseek-r1:7b etc. (rulat LOCAL, nu API China)

# --- ALERTE FAMILIE (fara continut de conversatie) ---
ALERT_ON_SCAM=true
ALERT_COOLDOWN=300
# ALERT_EMAIL_TO=fiul@example.com
# ALERT_SMTP_HOST=smtp.example.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=
# ALERT_SMTP_PASS=
# ALERT_WEBHOOK_URL=

# --- VOCE LOCALA optionala (GDPR-curata; monteaza ./voices in compose) ---
# PIPER_BIN=/voices/piper
# PIPER_VOICE_RO=/voices/ro_RO.onnx
# PIPER_VOICE_EN=/voices/en_GB.onnx
